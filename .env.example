# Google Gemini API Key
# Obtenha em: https://aistudio.google.com/apikey

# Opção 1 — chave única (uso simples)
GOOGLE_API_KEY=cole_sua_chave_aqui

# Opção 2 — múltiplas chaves separadas por vírgula (rotação automática ao esgotar cota)
# GOOGLE_API_KEYS=chave1,chave2,chave3

# Senha do painel administrativo
ADMIN_PASSWORD=sua_senha_aqui
